# ComplianceHub — AI Provider Configuration
#
# Modes (from most to least preferred):
#   Cloud AI: Set any API key below → router tries all cloud providers
#   Offline:  Leave ALL keys empty → offline generator (template-based, instant)
#   Local AI: Start llama-server, keep keys empty → router falls back to local
#
# Get API keys:
#   OpenRouter:  https://openrouter.ai/keys (free tier)
#   Groq:        https://console.groq.com/keys (free, no CC)
#   HuggingFace: https://huggingface.co/settings/tokens (free tier)

OPENROUTER_API_KEY=
GROQ_API_KEY=
HF_API_KEY=

# Legacy (optional, not actively used):
GEMINI_API_KEY=
OPENAI_API_KEY=
CLAUDE_API_KEY=
AGENTROUTER_API_KEY=
