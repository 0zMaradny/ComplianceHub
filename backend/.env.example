# ComplianceHub — Railway / Deployment Configuration
#
# Set these in Railway Dashboard → Variables, or in local .env for dev
#
# Modes:
#   Cloud AI: Set OPENROUTER_API_KEY + GROQ_API_KEY → 3-tier AI router (9 free models)
#   Offline:  Leave ALL keys empty → instant template-based generator
#   HF Tier:  Set HF_API_KEY → HuggingFace Llama-3-8B via free Inference API
#
# Get keys:
#   OpenRouter:  https://openrouter.ai/keys (free tier, no CC)
#   Groq:        https://console.groq.com/keys (free, ~800 t/s)
#   HuggingFace: https://huggingface.co/settings/tokens (free)

OPENROUTER_API_KEY=
GROQ_API_KEY=
HF_API_KEY=

# Railway auto-injects these; override here for local dev:
# PORT=8000
# DATABASE_URL=postgresql://user:pass@host:5432/compliancehub
