# ComplianceHub — Environment Configuration
#
# Cloud AI: Set OPENROUTER_API_KEY + GROQ_API_KEY → 4-tier AI router (11 free models)
# Offline:  Leave ALL keys empty → instant template-based generator (3.2s/8docs)
#
# Get keys:
#   OpenRouter:  https://openrouter.ai/keys (free tier, no CC)
#   Groq:        https://console.groq.com/keys (free, ~800 t/s)
#   HuggingFace: https://huggingface.co/settings/tokens (free)
#
# Railway auto-injects DATABASE_URL; override here for local dev.
#
# All vars are optional — defaults work out of the box for local dev.

# ── AI Provider Keys ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=          # Tier 0: Claude via Anthropic (paid, best quality)
OPENROUTER_API_KEY=          # Tier 1+2: OpenRouter (8 free frontier+strong models)
GROQ_API_KEY=                # Tier 3: Groq (free, ~800 t/s, Llama 3.3 70B)
HF_API_KEY=                  # Fallback: HuggingFace Inference Providers

# ── AI Router Config ────────────────────────────────────────────────────
# AI_DEGRADE_THRESHOLD=3       # Consecutive failures before skipping a provider
# AI_CACHE_TTL=3600            # Response cache TTL in seconds
# AI_BATCH_SIZE=2              # Parallel model calls per tier
# AI_PEAK_START=12             # OpenRouter peak hours start (UTC)
# AI_PEAK_END=18               # OpenRouter peak hours end (UTC)
# LOCAL_AI_BASE=http://localhost:8080
# LOCAL_AI_TIMEOUT=120         # Seconds before local AI request times out
# LOCAL_AI_MAX_RETRIES=2

# ── Server Config ───────────────────────────────────────────────────────
# PORT=8000
# CORS_ORIGINS=*               # Allowed CORS origins (comma-separated)
# MAX_FILE_SIZE=52428800       # 50 MB max upload file size
# MAX_JOB_AGE=3600             # Job cleanup age in seconds
# FRONTEND_STATIC_DIR=         # Path to built frontend dist/ for single-port serving

# ── Rate Limiting ───────────────────────────────────────────────────────
# RATE_LIMIT_WINDOW=60         # Sliding window in seconds
# RATE_LIMIT_MAX_REQUESTS=300  # Max requests per window per client IP

# ── Tunnel ──────────────────────────────────────────────────────────────
# TUNNEL_URL=                  # Last known tunnel URL (auto-set by tunnel.sh)
# TUNNEL_SECRET=               # Secret for tunnel URL updates (REQUIRED for live tunnel)

# ── Database ────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/compliancehub
